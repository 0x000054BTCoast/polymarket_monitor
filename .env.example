# Backend
APP_NAME=polymarket-monitor
ENV=dev
DATABASE_URL=sqlite:///./backend/data/polymarket_monitor.db

GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_BASE_URL=https://clob.polymarket.com
DATA_API_BASE_URL=https://data-api.polymarket.com
MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

DISCOVERY_POLL_SECONDS=60
SNAPSHOT_POLL_SECONDS=60
FLUSH_AGGREGATION_SECONDS=15
CLEANUP_CHECK_SECONDS=3600
WEBSOCKET_STALE_SECONDS=45
ROLLING_BASELINE_MINUTES=5
MAX_WS_BUFFER_MINUTES=30
DATA_RETENTION_HOURS=24

ALERT_PRICE_MOVE_1M_THRESHOLD=0.08
ALERT_NOTIONAL_SPIKE_MULTIPLE=3.0
DISABLE_BACKGROUND_JOBS=false

# Frontend
NEXT_PUBLIC_API_BASE=http://localhost:8000

LARK_ENABLED=false
LARK_WEBHOOK_URL=
LARK_SIGNING_SECRET=
LARK_DRY_RUN=true
SUMMARY_PUSH_CRON=0 */6 * * *
ALERT_PUSH_ENABLED=false
ALERT_PUSH_COOLDOWN_SECONDS=900

AI_AGENT_ENABLED=false
AI_AGENT_PROVIDER=
